{
  "name": "@seanhogg/ssmjs",
  "version": "1.0.0",
  "description": "JavaScript-native AI runtime — SSM execution, Transformer orchestration, online distillation, and persistent agent memory",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "type": "module",
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "test": "node --experimental-vm-modules node_modules/.bin/jest",
    "lint": "eslint src/ tests/",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mamba", "ssm", "state-space-model", "webgpu", "ai-runtime",
    "distillation", "online-learning", "agent", "transformer-bridge",
    "browser-ai", "typescript"
  ],
  "author": {
    "name": "Sean Hogg",
    "email": "seanhogg@gmail.com",
    "url": "https://builderforce.ai"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/SeanHogg/SSMjs.git"
  },
  "peerDependencies": {
    "@seanhogg/mambakit": "^1.0.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "@webgpu/types": "^0.1.49",
    "eslint": "^8.57.0",
    "fake-indexeddb": "^6.0.0",
    "jest": "^29.7.0",
    "@seanhogg/mambakit": "^1.0.0",
    "ts-jest": "^29.2.0",
    "typescript": "^5.0.0"
  },
  "jest": {
    "preset": "ts-jest/presets/default-esm",
    "extensionsToTreatAsEsm": [".ts"],
    "transform": {
      "^.+\\.tsx?$": [
        "ts-jest",
        {
          "useESM": true,
          "tsconfig": {
            "module": "ES2022",
            "moduleResolution": "bundler",
            "strict": true,
            "esModuleInterop": true,
            "skipLibCheck": true,
            "types": ["@webgpu/types", "jest"]
          }
        }
      ]
    },
    "moduleNameMapper": {
      "^(\\.{1,2}/.*)\\.js$": "$1"
    }
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
